" =============================================================================
"  ~/.vimrc — 极简轻量配置
"  仅偶尔在终端改配置文件 / 做命令行编辑，故只保留高频、无坑的核心项。
"  基于 Vim 9.1（macOS 自带 /usr/bin/vim）编写。
" =============================================================================

" -----------------------------------------------------------------------------
"  基础
" -----------------------------------------------------------------------------
set nocompatible                 " 关闭 vi 兼容，启用 Vim 完整特性
set encoding=utf-8               " 统一 UTF-8，避免中文乱码
set autoread                     " 文件被外部修改时自动重新载入
set backspace=indent,eol,start   " 退格可删除缩进/换行/插入起点前的字符

" -----------------------------------------------------------------------------
"  界面与提示
" -----------------------------------------------------------------------------
syntax on                        " 语法高亮
set number                       " 显示行号
set relativenumber               " 相对行号（配合 5j / 3k 快速跳转）
set ruler                        " 右下角显示光标行列号
set showcmd                      " 右下角回显正在输入的命令
set laststatus=2                 " 始终显示状态栏
set wildmenu                     " 命令行补全用可视菜单（Tab 触发）
set scrolloff=3                  " 光标上下保留 3 行余量，不贴屏幕边

" -----------------------------------------------------------------------------
"  缩进：统一 2 空格软 Tab（编辑 yaml / nu / lua 等配置最顺手）
" -----------------------------------------------------------------------------
filetype plugin indent on        " 按文件类型加载缩进/插件规则
set expandtab                    " Tab 转空格
set tabstop=2                    " 一个 Tab 显示为 2 空格
set shiftwidth=2                 " 自动缩进步长 2 空格
set softtabstop=2                " 编辑时 Tab/退格按 2 空格处理（修正旧配置的 4）
set autoindent                   " 换行沿用上一行缩进

" -----------------------------------------------------------------------------
"  搜索
" -----------------------------------------------------------------------------
set ignorecase                   " 搜索忽略大小写……
set smartcase                    " ……但含大写字母时自动区分
set incsearch                    " 边输入边高亮匹配
set hlsearch                     " 高亮所有匹配项
nnoremap <silent> <Esc><Esc> :nohlsearch<CR>   " 连按两下 Esc 清除高亮

" -----------------------------------------------------------------------------
"  粘贴：无需再 `set paste`
" -----------------------------------------------------------------------------
" 旧配置里的全局 `set paste` 会禁用自动缩进/映射/缩写，是常见坑。
" Vim 9.1 在支持 bracketed paste 的终端（含 Ghostty）里粘贴不会乱缩进，
" 因此这里直接不设 paste；粘贴大段文本保持原样即可（pastetoggle 已被 9.1 移除）。

" -----------------------------------------------------------------------------
"  可选（按需取消注释；本机 vim 已含 +clipboard / +mouse）
" -----------------------------------------------------------------------------
" set clipboard=unnamed          " y/p 直接走系统剪贴板（与 pbcopy/pbpaste 互通）
" set mouse=a                    " 启用鼠标（注意：终端原生「选中复制」需按住 Option）
" set cursorline                 " 高亮当前行
